{
  "name": "cliniko-capacity-desktop",
  "version": "0.1.0",
  "description": "Desktop (Electron) build of the Cliniko capacity dashboard",
  "private": true,
  "main": "build/main.js",
  "scripts": {
    "build:renderer": "cd .. && vite build --base=./ --outDir desktop/renderer --emptyOutDir",
    "build:main": "node build.mjs",
    "dev:renderer": "cd .. && vite",
    "dev:electron": "wait-on tcp:5280 && electron .",
    "dev": "npm run build:main && concurrently -k -n renderer,electron \"npm run dev:renderer\" \"npm run dev:electron\"",
    "build": "npm run build:main && npm run build:renderer",
    "dist": "npm run build && electron-builder",
    "release": "npm run build && electron-builder --publish always"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3",
    "esbuild": "^0.21.5",
    "wait-on": "^7.2.0"
  },
  "dependencies": {
    "electron-updater": "^6.2.1"
  }
}
